{
  "openapi": "3.0.3",
  "info": {
    "title": "HH Scout API",
    "version": "1.0.0",
    "description": "API for HH Scout Miniapp"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    { "name": "Jobs" },
    { "name": "Favorites" }
  ],
  "paths": {
    "/jobs": {
      "get": {
        "operationId": "searchJobs",
        "tags": ["Jobs"],
        "summary": "Search jobs",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "number", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          }
        }
      }
    },

    "/jobs/prefetch": {
      "get": {
        "operationId": "prefetchJobs",
        "tags": ["Jobs"],
        "summary": "Prefetch job descriptions",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "index",
            "in": "query",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Prefetch completed"
          }
        }
      }
    },

    "/jobs/{id}": {
      "get": {
        "operationId": "getJobById",
        "tags": ["Jobs"],
        "summary": "Get job by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          }
        }
      }
    },

    "/favorites": {
      "post": {
        "operationId": "saveFavorite",
        "tags": ["Favorites"],
        "summary": "Save favorite job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FavoriteCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite saved"
          }
        }
      }
    },

    "/favorites/{userId}": {
      "get": {
        "operationId": "getFavorites",
        "tags": ["Favorites"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Favorite jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Favorite"
                  }
                }
              }
            }
          }
        }
      }
    },

    "/favorites/{userId}/{jobId}": {
      "delete": {
        "operationId": "deleteFavorite",
        "tags": ["Favorites"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Favorite removed"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {

      "Job": {
        "type": "object",
        "required": ["id", "title", "company", "url", "description"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "url": { "type": "string" },
          "description": { "type": "string" }
        }
      },

      "Favorite": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "userId": { "type": "number" },
          "jobId": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "url": { "type": "string" }
        }
      },

      "FavoriteCreate": {
        "type": "object",
        "required": ["userId", "job"],
        "properties": {
          "userId": { "type": "number" },
          "job": {
            "$ref": "#/components/schemas/Job"
          }
        }
      },

      "SearchResult": {
        "type": "object",
        "required": ["items", "page", "pages", "found", "perPage"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          },
          "page": { "type": "number" },
          "pages": { "type": "number" },
          "found": { "type": "number" },
          "perPage": { "type": "number" }
        }
      }

    }
  }
}