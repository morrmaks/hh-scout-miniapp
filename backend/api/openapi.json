{
  "openapi": "3.0.3",
  "info": {
    "title": "HH Scout API",
    "version": "1.0.0",
    "description": "API for HH Scout Miniapp"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    { "name": "Jobs" },
    { "name": "Favorites" },
    { "name": "Areas" }
  ],
  "paths": {
    "/jobs": {
      "get": {
        "operationId": "searchJobs",
        "tags": ["Jobs"],
        "summary": "Search jobs",
        "parameters": [
          { "name": "text", "in": "query", "schema": { "type": "string" } },

          { "name": "page", "in": "query", "schema": { "type": "number", "default": 1 } },

          { "name": "index", "in": "query", "schema": { "type": "number" } },

          { "name": "per_page", "in": "query", "schema": { "type": "number", "default": 100 } },

          { "name": "order_by", "in": "query", "schema": { "type": "string" } },

          { "name": "salary", "in": "query", "schema": { "type": "number" } },

          { "name": "currency", "in": "query", "schema": { "type": "string" } },

          {
            "name": "experience",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "employment_form",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "work_format",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "work_schedule_by_days",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "area",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "label",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          { "name": "period", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          }
        }
      }
    },

    "/jobs/prefetch": {
      "get": {
        "operationId": "prefetchJobs",
        "tags": ["Jobs"],
        "summary": "Prefetch next jobs",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },

          { "name": "page", "in": "query", "required": true, "schema": { "type": "number" } },

          { "name": "index", "in": "query", "required": true, "schema": { "type": "number" } },

          { "name": "per_page", "in": "query", "schema": { "type": "number", "default": 100 } },

          { "name": "order_by", "in": "query", "schema": { "type": "string" } },

          { "name": "salary", "in": "query", "schema": { "type": "number" } },

          { "name": "currency", "in": "query", "schema": { "type": "string" } },

          {
            "name": "experience",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "employment_form",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "work_format",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "work_schedule_by_days",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "area",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          {
            "name": "label",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },

          { "name": "period", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "Prefetched jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Job"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "SearchResult": {
        "type": "object",
        "required": ["items", "page", "pages", "found", "perPage", "pageItems"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          },
          "page": { "type": "number" },
          "pages": { "type": "number" },
          "found": { "type": "number" },
          "perPage": { "type": "number" },
          "pageItems": { "type": "number" }
        }
      }
    }
  }
}