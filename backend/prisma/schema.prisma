generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Favorite {
  id      Int    @id @default(autoincrement())
  userId  Int
  jobId   String
  title   String
  company String
  url     String

  @@unique([userId, jobId])
}

model Position {
  id     Int @id @default(autoincrement())
  userId Int @unique
  query  String
  page   Int
  index  Int
}