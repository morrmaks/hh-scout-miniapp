generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  UZS 
  USD 
  UAH 
  RUR 
  KZT 
  KGS 
  GEL 
  EUR 
  BYR 
  AZN
}

model Company {
  id Int @id @default(autoincrement())

  userId Int
  name   String

  @@unique([userId, name])
}

model Status {
  id       Int @id @default(autoincrement())

  userId   Int
  name     String
  color    String

  applications Application[]

  @@index([userId])
}

model Favorite {
  id     Int @id @default(autoincrement())
  userId Int
  jobId  String

  title   String
  company String
  url     String

  salaryFrom Int?
  salaryTo   Int?
  currency   Currency?

  salaryBase Int?

  experience  String?
  publishedAt DateTime?

  createdAt DateTime @default(now())

  applications Application[]

  @@unique([userId, jobId])
  @@index([userId])
}

model Resume {
  id      Int @id @default(autoincrement())
  userId  Int
  name    String

  applications Application[]

  @@index([userId])
}

model Application {
  id Int @id @default(autoincrement())

  userId Int

  favoriteId Int
  resumeId   Int
  statusId   Int?

  favorite Favorite @relation(fields: [favoriteId], references: [id])
  resume   Resume   @relation(fields: [resumeId], references: [id])
  status   Status?  @relation(fields: [statusId], references: [id])

  @@unique([favoriteId, resumeId])
  @@index([resumeId])
  @@index([statusId])
  @@index([userId])
}