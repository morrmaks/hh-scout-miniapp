generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id Int @id @default(autoincrement())

  userId Int
  name   String

  @@unique([userId, name])
}

model Status {
  id       Int @id @default(autoincrement())

  userId   Int
  name     String
  color    String

  favorites Favorite[]

  @@index([userId])
}

model Favorite {
  id Int @id @default(autoincrement())

  userId Int
  jobId  String

  title   String
  company String
  url     String

  salaryFrom Int?
  salaryTo   Int?
  currency   String?

  experience String?

  publishedAt DateTime?
  createdAt DateTime @default(now())

  statusId Int?
  status   Status? @relation(fields: [statusId], references: [id])

  @@unique([userId, jobId])
  @@index([userId])
}