generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  UZS 
  USD 
  UAH 
  RUR 
  KZT 
  KGS 
  GEL 
  EUR 
  BYR 
  AZN
}

model Company {
  id Int @id @default(autoincrement())

  userId Int
  name   String

  @@unique([userId, name])
}

model Status {
  id       Int @id @default(autoincrement())

  userId   Int
  name     String
  color    String

  favorites Favorite[]

  @@index([userId])
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  jobId      String

  title      String
  company    String
  url        String

  salaryFrom Int?
  salaryTo   Int?
  currency   Currency?

  salaryBase Int?

  experience String?
  publishedAt DateTime?

  statusId   Int?
  status     Status? @relation(fields: [statusId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([userId, jobId])
  @@index([salaryBase])
}