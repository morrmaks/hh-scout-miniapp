generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Favorite {
  id        Int     @id @default(autoincrement())

  userId    Int
  jobId     String

  title     String
  company   String
  url       String

  salaryFrom Int?
  salaryTo   Int?
  currency   String?

  experience String?

  @@unique([userId, jobId])
}