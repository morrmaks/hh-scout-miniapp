{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": "./",
    "rootDir": "./",
    "module": "commonjs",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
