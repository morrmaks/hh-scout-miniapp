{
  "name": "hh-scout-backend",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "precommit": "pretty-quick --staged"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@telegram-apps/init-data-node": "^2.0.10",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "he": "^1.2.0",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@siberiacancode/eslint": "^2.16.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/he": "^1.2.3",
    "@types/node": "^25.3.3",
    "@types/node-telegram-bot-api": "^0.64.14",
    "husky": "^9.1.7",
    "pretty-quick": "^4.2.2",
    "prisma": "^7.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
